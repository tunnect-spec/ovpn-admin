# =============================================================================
# Environment configuration. Copy to `.env` and replace EVERY value below.
# The application REFUSES to start in production with missing or default
# secrets — generate strong values, e.g.:  openssl rand -base64 48
# =============================================================================

# Database
DATABASE_URL="postgresql://ovpn:CHANGE_ME@localhost:5432/ovpn_admin"
# Used by docker/compose.yml for the postgres container + DATABASE_URL it builds.
POSTGRES_PASSWORD="CHANGE_ME"

# Redis (set a password in production: redis://:PASSWORD@host:6379)
REDIS_URL="redis://localhost:6379"

# Security — REQUIRED, no defaults are accepted in production.
# Generate each independently with: openssl rand -base64 48
JWT_SECRET="REPLACE_WITH_openssl_rand_base64_48"        # min 32 chars
ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_RANDOM_KEY"        # min 32 chars (AES-256)
API_TOKEN_SALT="REPLACE_WITH_openssl_rand_base64_32"    # min 16 chars

# Application URLs (used to build agent install commands — must be HTTPS in prod)
NEXT_PUBLIC_APP_URL="https://panel.example.com"
PANEL_URL="https://panel.example.com"

# Environment
NODE_ENV="development"

# Initial admin seed (used by `pnpm db:seed`; REQUIRED in production)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD=""

# Agent Configuration
AGENT_HEARTBEAT_INTERVAL="30"
AGENT_HEARTBEAT_TIMEOUT="5"
