# Database
DATABASE_URL="postgresql://ovpn:your_password_here@localhost:5432/ovpn_admin"

# Redis
REDIS_URL="redis://localhost:6379"

# Security (CHANGE THESE IN PRODUCTION!)
JWT_SECRET="change_me_in_production_please_use_32_chars_or_more"
ENCRYPTION_KEY="default_encryption_key_change_me_32b"
PASSWORD_SALT="default_salt"
API_TOKEN_SALT="default_api_salt"

# Application URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
PANEL_URL="http://localhost:3000"

# Environment
NODE_ENV="development"

# Agent Configuration
AGENT_HEARTBEAT_INTERVAL="30"
AGENT_HEARTBEAT_TIMEOUT="5"
