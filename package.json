{
  "name": "ovpn-admin",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter @ovpn/panel dev\" \"pnpm --filter @ovpn/worker dev\"",
    "build": "pnpm -r build",
    "build:panel": "pnpm --filter @ovpn/panel build",
    "build:worker": "pnpm --filter @ovpn/worker build",
    "build:agent": "pnpm --filter @ovpn/agent build",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate": "prisma migrate dev",
    "docker:up": "docker compose -f docker/compose.yml up -d",
    "docker:down": "docker compose -f docker/compose.yml down",
    "docker:logs": "docker compose -f docker/compose.yml logs -f"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "concurrently": "^10.0.3",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "pg": "^8.22.0"
  },
  "pnpm.onlyBuiltDependencies": [
    "@prisma/engines",
    "esbuild",
    "prisma"
  ]
}
